<UserControl x:Class="PCLrmkBYCSharp.Views.Pages.LaunchPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:PCLrmkBYCSharp.Models"
             Background="{StaticResource AppBackgroundBrush}"
             Foreground="{StaticResource AppTextBrush}">
    <UserControl.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="32" />
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource DarkComboBoxStyle}">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource DarkComboBoxItemStyle}">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Padding" Value="8,6" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AppHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Padding" Value="12,7" />
        </Style>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,12,0,6" />
        </Style>
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="PrimaryLaunchButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AppAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="19" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="58" />
            <Setter Property="Padding" Value="24,0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="启动游戏" FontSize="25" FontWeight="SemiBold" />
                        <TextBlock Text="选择版本后即可按 PCL 的流程生成参数或启动。"
                                   Margin="0,7,0,0"
                                   Style="{StaticResource MutedTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                    <Grid MinHeight="230">
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsVersionSelectorOpen}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="当前版本" Style="{StaticResource SectionTitleStyle}" />
                            <Border Background="{StaticResource AppPanelBrush}"
                                    BorderBrush="{StaticResource AppAccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="13">
                                <StackPanel>
                                    <TextBlock Text="{Binding CurrentVersionTitle}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding CurrentVersionSubtitle}"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                </StackPanel>
                            </Border>
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Command="{Binding OpenVersionSelectorCommand}"
                                        Content="版本选择" />
                                <Button Grid.Column="2"
                                        Command="{Binding DataContext.OpenInstanceManagementCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding SelectedInstance}"
                                        Content="版本设置">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSelectedInstance}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                            <TextBlock Text="{Binding SelectedInstanceSummary}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextStyle}" />
                            <TextBlock Text="{Binding InstanceLaunchSettingsSummary}"
                                       Margin="0,5,0,0"
                                       Style="{StaticResource MutedTextStyle}" />

                            <Grid Margin="0,20,0,0">
                                <Button Command="{Binding LaunchGameCommand}"
                                        Content="启动游戏">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryLaunchButtonStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSelectedInstance}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{x:Static models:PageRoute.Download}"
                                        Content="下载游戏">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryLaunchButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasNoSelectedInstance}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Command="{Binding GenerateProfileCommand}"
                                        Content="生成参数"
                                        IsEnabled="{Binding HasSelectedInstance}" />
                                <Button Grid.Column="2"
                                        Command="{Binding ExportLaunchScriptCommand}"
                                        Content="导出脚本"
                                        IsEnabled="{Binding HasSelectedInstance}" />
                            </Grid>

                            <TextBlock Text="{Binding StatusMessage}"
                                       Margin="0,12,0,0"
                                       Foreground="{StaticResource AppAccentBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsVersionSelectorOpen}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="220" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="版本选择"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <Button Grid.Column="1"
                                        Command="{Binding CloseVersionSelectorCommand}"
                                        Content="返回"
                                        Padding="10,4"
                                        MinHeight="26" />
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding VersionSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="搜索版本名、版本号、加载器或描述" />
                                <ComboBox Grid.Column="2"
                                          Width="130"
                                          ItemsSource="{Binding VersionSortOptions}"
                                          SelectedValue="{Binding VersionSortMode, Mode=TwoWay}"
                                          SelectedValuePath="Value"
                                          DisplayMemberPath="DisplayName"
                                          ToolTip="版本排序" />
                                <CheckBox Grid.Column="4"
                                          Content="显示隐藏版本"
                                          IsChecked="{Binding ShowHiddenVersions, Mode=TwoWay}"
                                          Foreground="{StaticResource AppTextBrush}"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock Grid.Row="3"
                                       Text="{Binding VersionSelectorSummary}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextStyle}" />

                            <ListBox Grid.Row="4"
                                     ItemsSource="{Binding VersionSelectorRows}"
                                     SelectedItem="{Binding SelectedVersionSelectorRow, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource AppTextBrush}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="MinHeight" Value="0" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.Style>
                                    <Style TargetType="ListBox">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasVersionSelectorRows}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Border Background="{StaticResource AppAccentSoftBrush}"
                                                    BorderBrush="{StaticResource AppAccentBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="5"
                                                    Padding="10,6"
                                                    Margin="0,0,0,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding GroupTitle}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource AppAccentBrush}" />
                                            </Border>
                                            <Border CornerRadius="5"
                                                    Padding="10"
                                                    Margin="0,0,0,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsCurrentLaunchVersion}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="34" />
                                                        <ColumnDefinition Width="12" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Command="{Binding DataContext.SelectVersionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding Instance}"
                                                            Grid.Column="0"
                                                            Grid.ColumnSpan="3"
                                                            HorizontalContentAlignment="Stretch"
                                                            Padding="0"
                                                            BorderThickness="0"
                                                            Background="Transparent"
                                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="设为启动版本"
                                                                          Command="{Binding PlacementTarget.Tag.SelectVersionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext.Instance, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                                <MenuItem Header="打开版本文件夹"
                                                                          Command="{Binding PlacementTarget.Tag.OpenVersionFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext.Instance, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                                <Separator />
                                                                <MenuItem Header="收藏/取消收藏"
                                                                          Command="{Binding PlacementTarget.Tag.ToggleVersionStarCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext.Instance, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                                <MenuItem Header="隐藏/取消隐藏"
                                                                          Command="{Binding PlacementTarget.Tag.ToggleVersionHiddenCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext.Instance, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                                <Separator />
                                                                <MenuItem Header="删除版本"
                                                                          Command="{Binding PlacementTarget.Tag.DeleteVersionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext.Instance, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="34" />
                                                                <ColumnDefinition Width="12" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Width="34"
                                                                    Height="34"
                                                                    VerticalAlignment="Top"
                                                                    Background="{StaticResource AppSurfaceBrush}"
                                                                    BorderBrush="{StaticResource AppBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="5"
                                                                    ToolTip="{Binding IconDescription}">
                                                                <Image Source="{Binding IconPath}"
                                                                       Width="24"
                                                                       Height="24"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                                            </Border>
                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding DisplayVersion}"
                                                                           Margin="0,5,0,0"
                                                                           FontSize="12"
                                                                           Foreground="{StaticResource AppMutedTextBrush}" />
                                                                <TextBlock Text="{Binding LoaderSummary}"
                                                                           Margin="0,4,0,0"
                                                                           FontSize="12"
                                                                           Foreground="{StaticResource AppMutedTextBrush}" />
                                                                <TextBlock Text="{Binding DisplayInfo}"
                                                                           Margin="0,4,0,0"
                                                                           FontSize="12"
                                                                           Foreground="{StaticResource AppMutedTextBrush}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Button>
                                                    <StackPanel Grid.Column="3"
                                                                Margin="12,0,0,0"
                                                                MinWidth="84">
                                                        <TextBlock Text="{Binding CurrentLaunchText}"
                                                                   FontWeight="SemiBold"
                                                                   HorizontalAlignment="Right"
                                                                   Foreground="{StaticResource AppAccentBrush}" />
                                                        <TextBlock Text="{Binding StarText}"
                                                                   Margin="0,4,0,0"
                                                                   HorizontalAlignment="Right"
                                                                   Foreground="{StaticResource AppAccentBrush}" />
                                                        <TextBlock Text="{Binding HiddenText}"
                                                                   Margin="0,4,0,0"
                                                                   HorizontalAlignment="Right"
                                                                   Foreground="{StaticResource AppMutedTextBrush}" />
                                                        <Button Command="{Binding DataContext.OpenInstanceManagementCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding Instance}"
                                                                Content="管理"
                                                                Margin="0,8,0,0"
                                                                Padding="10,4"
                                                                MinHeight="26"
                                                                MinWidth="70"
                                                                HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Border Grid.Row="4"
                                    Background="{StaticResource AppPanelBrush}"
                                    BorderBrush="{StaticResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="14">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasVersionSelectorRows}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="无可用版本"
                                               HorizontalAlignment="Center"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding VersionSelectorEmptyText}"
                                               Margin="0,8,0,0"
                                               TextAlignment="Center"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Command="{Binding RefreshInstancesCommand}"
                                        Content="刷新版本" />
                                <Button Grid.Column="2"
                                        Command="{Binding CloseVersionSelectorCommand}"
                                        Content="取消" />
                            </Grid>
                        </Grid>

                        <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="正在启动游戏"
                                       HorizontalAlignment="Center"
                                       FontSize="21"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedInstanceSummary}"
                                       HorizontalAlignment="Center"
                                       Margin="0,7,0,0"
                                       Style="{StaticResource MutedTextStyle}" />
                            <ProgressBar Height="4"
                                         Margin="20,18,20,18"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding LaunchProgressPercent, Mode=OneWay}"
                                         Background="{StaticResource AppBorderBrush}"
                                         Foreground="{StaticResource AppAccentBrush}" />
                            <Grid HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                 <Grid.RowDefinitions>
                                     <RowDefinition Height="Auto" />
                                     <RowDefinition Height="Auto" />
                                     <RowDefinition Height="Auto" />
                                 </Grid.RowDefinitions>
                                 <TextBlock Text="当前步骤" Opacity="0.55" />
                                 <TextBlock Grid.Column="2"
                                           Text="{Binding LaunchCurrentStepText}"
                                           Foreground="{StaticResource AppAccentBrush}" />
                                 <TextBlock Grid.Row="1"
                                            Text="登录方式"
                                           Margin="0,7,0,0"
                                           Opacity="0.55" />
                                 <TextBlock Grid.Row="1"
                                            Grid.Column="2"
                                             Text="{Binding SelectedLoginTypeDisplayName}"
                                             Margin="0,7,0,0"
                                             Foreground="{StaticResource AppMutedTextBrush}" />
                                 <TextBlock Grid.Row="2"
                                             Text="启动进度"
                                            Margin="0,7,0,0"
                                            Opacity="0.55" />
                                 <TextBlock Grid.Row="2"
                                            Grid.Column="2"
                                            Text="{Binding LaunchProgressText}"
                                            Margin="0,7,0,0"
                                            Foreground="{StaticResource AppMutedTextBrush}" />
                             </Grid>
                             <Button Command="{Binding CancelBusyCommand}"
                                     Content="取消"
                                     Width="120"
                                     Margin="0,18,0,0"
                                     HorizontalAlignment="Center" />
                         </StackPanel>
                     </Grid>
                 </Border>

                <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Minecraft 文件夹" Style="{StaticResource SectionTitleStyle}" />
                        <TextBox Grid.Row="2"
                                 Text="{Binding MinecraftRootPath}"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap" />
                        <ListBox Grid.Row="4"
                                 ItemsSource="{Binding MinecraftRootFolders}"
                                 SelectedItem="{Binding SelectedMinecraftRootFolder, Mode=TwoWay}"
                                 MinHeight="150"
                                 Background="Transparent"
                                 BorderBrush="{StaticResource AppBorderBrush}"
                                 Foreground="{StaticResource AppTextBrush}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4" Height="72">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Image Source="/Resources/Images/Blocks/Grass.png"
                                               Width="28"
                                               Height="28"
                                               VerticalAlignment="Top"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                        <StackPanel Grid.Column="2">
                                            <DockPanel>
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding CurrentText}"
                                                           Margin="10,0,0,0"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource AppAccentBrush}" />
                                            </DockPanel>
                                            <TextBlock Text="{Binding Path}"
                                                       Margin="0,3,0,0"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{StaticResource AppMutedTextBrush}" />
                                            <WrapPanel Margin="0,4,0,0">
                                                <TextBlock Text="{Binding TypeText}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource AppMutedTextBrush}" />
                                                <TextBlock Text="{Binding VersionCountText}"
                                                           Margin="10,0,0,0"
                                                           FontSize="11"
                                                           Foreground="{StaticResource AppMutedTextBrush}" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Grid Grid.Row="6" VerticalAlignment="Bottom">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Command="{Binding BrowseMinecraftRootCommand}"
                                    Content="添加文件夹" />
                            <Button Grid.Column="2"
                                    Command="{Binding RenameMinecraftRootCommand}"
                                    Content="重命名" />
                            <Button Grid.Column="4"
                                    Command="{Binding RemoveMinecraftRootCommand}"
                                    Content="移除" />
                            <Button Grid.Row="2"
                                    Grid.ColumnSpan="2"
                                    Command="{Binding OpenMinecraftRootCommand}"
                                    Content="打开文件夹" />
                            <Button Grid.Row="2"
                                    Grid.Column="2"
                                    Grid.ColumnSpan="3"
                                    Command="{Binding RefreshInstancesCommand}"
                                    Content="刷新版本" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="0.95*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="登录方式" Style="{StaticResource SectionTitleStyle}" />
                            <ComboBox ItemsSource="{Binding LoginTypeOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding SelectedLoginType, Mode=TwoWay}" />

                            <StackPanel Margin="0,12,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMicrosoftLogin}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding MicrosoftClientIdHelp}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                    <Button Grid.Column="2"
                                            MinWidth="116"
                                            Command="{Binding ToggleMicrosoftClientIdEditorCommand}"
                                            Content="{Binding MicrosoftClientIdEditorActionText}" />
                                </Grid>
                                <StackPanel Margin="0,10,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMicrosoftClientIdEditorVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="Microsoft Client ID" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox Text="{Binding MicrosoftClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0,12,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMicrosoftLogin}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="{Binding MicrosoftAccountSummary}"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource AppMutedTextBrush}" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding MicrosoftReadinessSummary}"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource AppAccentBrush}" />
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="{Binding MicrosoftAccountHistorySummary}"
                                               Style="{StaticResource LabelTextStyle}" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasMicrosoftAccountHistory}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox ItemsSource="{Binding MicrosoftAccounts}"
                                                  SelectedItem="{Binding SelectedMicrosoftAccount, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Uuid}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource AppMutedTextBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Button Grid.Column="2"
                                                Command="{Binding SwitchMicrosoftAccountCommand}"
                                                Content="切换" />
                                        <Button Grid.Column="4"
                                                Command="{Binding DeleteMicrosoftAccountCommand}"
                                                Content="删除" />
                                    </Grid>
                                </StackPanel>
                                <Border Margin="0,10,0,0"
                                        Padding="12"
                                        Background="{StaticResource AppAccentSoftBrush}"
                                        BorderBrush="{StaticResource AppAccentBrush}"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMicrosoftDeviceCodeActive}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="等待微软网页登录授权"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AppTextBrush}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding MicrosoftDeviceCodeMessage}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource AppMutedTextBrush}" />
                                        <TextBox Margin="0,10,0,0"
                                                 Text="{Binding MicrosoftDeviceCode}"
                                                 IsReadOnly="True"
                                                 HorizontalContentAlignment="Center"
                                                 FontSize="22"
                                                 FontWeight="SemiBold" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding MicrosoftDeviceCodeVerificationUri}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource AppAccentBrush}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding MicrosoftDeviceCodeExpiresText}"
                                                   Foreground="{StaticResource AppMutedTextBrush}" />
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Command="{Binding OpenMicrosoftDeviceCodePageCommand}"
                                                    Content="打开验证页" />
                                            <Button Grid.Column="2"
                                                    Command="{Binding CopyMicrosoftDeviceCodeCommand}"
                                                    Content="复制代码" />
                                            <Button Grid.Column="4"
                                                    Command="{Binding CancelBusyCommand}"
                                                    Content="取消登录" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="0.8*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Command="{Binding RefreshMicrosoftAccountCommand}"
                                            Content="刷新授权"
                                            ToolTip="{Binding MicrosoftRefreshUnavailableReason}"
                                            ToolTipService.ShowOnDisabled="True" />
                                    <Button Grid.Column="2"
                                            Command="{Binding LoginMicrosoftAccountCommand}"
                                            Content="{Binding MicrosoftLoginActionText}"
                                            ToolTip="{Binding MicrosoftLoginUnavailableReason}"
                                            ToolTipService.ShowOnDisabled="True" />
                                    <Button Grid.Column="4"
                                            Command="{Binding LogoutMicrosoftAccountCommand}"
                                            Content="退出账号" />
                                </Grid>
                            </StackPanel>

                            <Grid Margin="0,8,0,0">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLegacyLogin}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="离线用户名" Style="{StaticResource LabelTextStyle}" />
                                <ComboBox Grid.Row="1"
                                          IsEditable="True"
                                          ItemsSource="{Binding LegacyNameHistory}"
                                          Text="{Binding LegacyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                    <TextBlock Text="离线皮肤" Style="{StaticResource LabelTextStyle}" />
                                    <ComboBox ItemsSource="{Binding LegacySkinTypeOptions}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding LaunchSkinType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLegacySkinIdVisible}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding LegacySkinIdLabel}" Style="{StaticResource LabelTextStyle}" />
                                        <TextBox Grid.Row="1"
                                                 Text="{Binding LaunchSkinId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Grid Grid.Row="1" Grid.Column="2">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLegacySkinBrowseVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Button Command="{Binding BrowseLegacySkinCommand}"
                                                    Content="浏览..." />
                                        </Grid>
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLegacySkinSlimVisible}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <CheckBox Content="使用 Alex 细臂模型"
                                                  IsChecked="{Binding LaunchSkinSlim, Mode=TwoWay}"
                                                  Foreground="{StaticResource AppTextBrush}" />
                                    </Grid>
                                    <TextBlock Text="{Binding LegacySkinSummary}"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsServerLogin}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="账号" Style="{StaticResource LabelTextStyle}" />
                                <ComboBox Grid.Row="1"
                                          IsEditable="True"
                                          ItemsSource="{Binding LoginUserNameHistory}"
                                          Text="{Binding LoginUserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="2" Text="密码" Style="{StaticResource LabelTextStyle}" />
                                <TextBox Grid.Row="3"
                                         Text="{Binding LoginPassword, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="4" Text="验证服务器" Style="{StaticResource LabelTextStyle}" />
                                <TextBox Grid.Row="5"
                                         Text="{Binding LoginServer, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid Margin="0,12,0,0">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsServerLogin}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding ServerAccountSummary}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AppMutedTextBrush}" />
                                <Button Grid.Column="2"
                                        Command="{Binding LoginServerAccountCommand}"
                                        Content="登录/重新登录" />
                                <Button Grid.Column="4"
                                        Command="{Binding LogoutServerAccountCommand}"
                                        Content="退出账号" />
                            </Grid>

                            <CheckBox Content="记住登录信息"
                                      Margin="0,14,0,0"
                                      IsChecked="{Binding RememberLogin, Mode=TwoWay}"
                                      Foreground="{StaticResource AppTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Java" Style="{StaticResource SectionTitleStyle}" />
                            <ComboBox ItemsSource="{Binding JavaEntries}"
                                      SelectedItem="{Binding SelectedJava, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text="{Binding SelectedJavaSummary}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextStyle}" />
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Command="{Binding BrowseJavaCommand}"
                                        Content="选择文件" />
                                <Button Grid.Column="2"
                                        Command="{Binding ScanJavaCommand}"
                                        Content="扫描 Java" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="启动行为" Style="{StaticResource SectionTitleStyle}" />
                            <ComboBox ItemsSource="{Binding LauncherVisibilityOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding LauncherVisibility, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="窗口模式" Style="{StaticResource SectionTitleStyle}" />
                            <ComboBox ItemsSource="{Binding WindowTypeOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding LaunchWindowType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <Grid Grid.Column="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="宽度" Style="{StaticResource SectionTitleStyle}" />
                                <TextBox Text="{Binding LaunchWindowWidth, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="高度" Style="{StaticResource SectionTitleStyle}" />
                                <TextBox Text="{Binding LaunchWindowHeight, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="启动状态" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding StatusMessage}"
                                       Foreground="{StaticResource AppAccentBrush}"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <ItemsControl Grid.Row="2" ItemsSource="{Binding Steps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="105" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Status}"
                                                   Foreground="{StaticResource AppMutedTextBrush}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Message}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource AppMutedTextBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Grid.Row="4">
                            <Border Background="{StaticResource AppPanelBrush}"
                                    BorderBrush="{StaticResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="12"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="文件补全"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding FileCompletionSummary}"
                                               Foreground="{StaticResource AppAccentBrush}"
                                               TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding FileCompletionDetails}"
                                                  Margin="0,6,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource AppMutedTextBrush}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource AppPanelBrush}"
                                    BorderBrush="{StaticResource AppAccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="12"
                                    Margin="0,0,0,12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasLaunchDiagnostics}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="启动诊断"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding LaunchDiagnostics}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                    <Button Margin="0,12,0,0"
                                            HorizontalAlignment="Left"
                                            MinWidth="168"
                                            Command="{Binding DataContext.OpenInstanceManagementCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding SelectedInstance}"
                                            Content="前往实例页补全文件">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasLaunchFileCompletionAction}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Margin="0,8,0,0"
                                            HorizontalAlignment="Left"
                                            MinWidth="148"
                                            Command="{Binding DataContext.OpenDownloadManagementCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Content="查看下载任务">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasLaunchFileCompletionAction}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <TextBox Text="{Binding CommandPreview}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="116"
                                     VerticalScrollBarVisibility="Auto"
                                     IsReadOnly="True" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
    </Grid>
</UserControl>
