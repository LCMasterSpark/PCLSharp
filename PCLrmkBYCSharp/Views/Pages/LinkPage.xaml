<UserControl x:Class="PCLrmkBYCSharp.Views.Pages.LinkPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}"
             Foreground="{StaticResource AppTextBrush}">
    <UserControl.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template" Value="{StaticResource DarkButtonTemplate}" />
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource DarkComboBoxStyle}">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title}" FontSize="30" FontWeight="SemiBold" />
        <TextBlock Grid.Row="1"
                   Text="{Binding Subtitle}"
                   Margin="0,8,0,22"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   FontSize="14" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" MinWidth="420" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1.45*" MinWidth="560" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="创建房间" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="按 PCL 邀请码规则生成房间信息，并同步生成陶瓦联机 / EasyTier 的启动计划。"
                               Margin="0,6,0,14"
                               Style="{StaticResource MutedTextStyle}" />

                    <TextBlock Text="本地游戏端口" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}" />

                    <UniformGrid Columns="2" Margin="0,14,0,0">
                        <Button Content="生成邀请码"
                                Margin="0,0,6,0"
                                Command="{Binding CreateRoomCommand}" />
                        <Button Content="复制邀请码"
                                Margin="6,0,0,0"
                                Command="{Binding CopyInviteCodeCommand}" />
                    </UniformGrid>

                    <TextBlock Text="邀请码"
                               Margin="0,16,0,6"
                               Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Text="{Binding GeneratedInviteCode}" IsReadOnly="True" />

                    <TextBlock Text="{Binding ShareText}"
                               Margin="0,10,0,0"
                               LineHeight="20"
                               Style="{StaticResource MutedTextStyle}" />
                    <Button Content="复制分享文本"
                            Margin="0,10,0,0"
                            Command="{Binding CopyShareTextCommand}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="加入房间" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="识别原 PCL / PCL Sharp 邀请码，校验后会显示加入房间的启动计划。"
                               Margin="0,6,0,14"
                               Style="{StaticResource MutedTextStyle}" />

                    <TextBlock Text="房间邀请码" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Text="{Binding InviteCodeInput, UpdateSourceTrigger=PropertyChanged}" />

                    <UniformGrid Columns="2" Margin="0,14,0,0">
                        <Button Content="验证邀请码"
                                Margin="0,0,6,0"
                                Command="{Binding ValidateInviteCommand}" />
                        <Button Content="加入房间"
                                Margin="6,0,0,0"
                                Command="{Binding JoinRoomCommand}" />
                    </UniformGrid>

                    <TextBlock Text="{Binding ParsedInviteSummary}"
                               Margin="0,12,0,0"
                               LineHeight="20"
                               Style="{StaticResource MutedTextStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Grid.RowSpan="3"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="联机方案" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="陶瓦联机作为默认入口，EasyTier 作为底层 VPN / 高级模式保留。当前可检测本地后端、生成启动计划并启动进程。"
                                   Margin="0,6,0,16"
                                   Style="{StaticResource MutedTextStyle}" />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="默认方案" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox ItemsSource="{Binding ProviderOptions}"
                                      SelectedItem="{Binding SelectedProvider, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName" />
                            <TextBlock Text="{Binding SelectedProvider.Description}"
                                       Margin="0,7,0,0"
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="连接偏好" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox ItemsSource="{Binding LatencyOptions}"
                                      SelectedItem="{Binding SelectedLatencyMode, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName" />
                            <TextBlock Text="{Binding SelectedLatencyMode.Description}"
                                       Margin="0,7,0,0"
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2"
                            Margin="0,18,0,0"
                            Padding="14"
                            Background="{StaticResource AppPanelBrush}"
                            BorderBrush="{StaticResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="联机后端" FontWeight="SemiBold" />
                            <UniformGrid Grid.Column="1"
                                         Columns="2">
                                <Button Content="自动查找"
                                        MinWidth="96"
                                        Margin="0,0,8,0"
                                        Command="{Binding AutoDetectBackendExecutableCommand}" />
                                <Button Content="选择文件"
                                        MinWidth="96"
                                        Command="{Binding PickSelectedBackendExecutableCommand}" />
                            </UniformGrid>

                            <StackPanel Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,8,0,10">
                                <TextBlock Text="{Binding BackendStatusText}"
                                           Foreground="{StaticResource AppAccentBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding BackendDiagnosticText}"
                                           Margin="0,5,0,0"
                                           FontSize="12"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Text="Terracotta"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     Width="360"
                                     Text="{Binding TerracottaExecutablePath}"
                                     IsReadOnly="True" />

                            <TextBlock Grid.Row="3"
                                       Text="EasyTier"
                                       Margin="0,10,12,0"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Row="3"
                                     Grid.Column="1"
                                     Width="360"
                                     Margin="0,8,0,0"
                                     Text="{Binding EasyTierExecutablePath}"
                                     IsReadOnly="True" />

                            <TextBlock Grid.Row="4"
                                       Grid.ColumnSpan="2"
                                       Text="正式打包前需要确认 Terracotta / EasyTier 的许可证与二进制分发方式；当前可手动选择后端并启动本地进程。"
                                       Margin="0,10,0,0"
                                       Style="{StaticResource MutedTextStyle}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Margin="0,18,0,0"
                            Padding="14"
                            Background="{StaticResource AppPanelBrush}"
                            BorderBrush="{StaticResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="启动计划" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding BackendPlanText}"
                                       Margin="0,8,0,0"
                                       LineHeight="21"
                                       Style="{StaticResource MutedTextStyle}" />
                            <UniformGrid Columns="4" Margin="0,14,0,0">
                                <Button Content="启动联机后端"
                                        Margin="0,0,6,0"
                                        Command="{Binding StartBackendCommand}" />
                                <Button Content="停止联机后端"
                                        Margin="6,0"
                                        Command="{Binding StopBackendCommand}" />
                                <Button Content="复制计划"
                                        Margin="6,0"
                                        Command="{Binding CopyLaunchPlanCommand}" />
                                <Button Content="重试"
                                        Margin="6,0,0,0"
                                        Command="{Binding RetryBackendCommand}" />
                            </UniformGrid>
                            <TextBlock Text="{Binding LinkProcessStatusText}"
                                       Margin="0,12,0,0"
                                       LineHeight="21"
                                       Foreground="{StaticResource AppAccentBrush}"
                                       TextWrapping="Wrap" />
                            <Border Margin="0,10,0,0"
                                    Padding="10,8"
                                    Background="{StaticResource AppAccentSoftBrush}"
                                    BorderBrush="{StaticResource AppAccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <TextBlock Text="{Binding LinkConnectionStatusText}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AppTextBrush}"
                                           TextWrapping="Wrap" />
                            </Border>
                            <TextBlock Text="{Binding LinkConnectedPeersText}"
                                       Margin="0,7,0,0"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       LineHeight="18"
                                       Style="{StaticResource MutedTextStyle}" />
                            <TextBlock Text="近期日志"
                                       Margin="0,12,0,6"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Text="{Binding LinkProcessLogFileText}"
                                       Margin="0,0,0,6"
                                       FontSize="12"
                                       Style="{StaticResource MutedTextStyle}" />
                            <Border MinHeight="76"
                                    Padding="10"
                                    Background="{StaticResource AppCardBrush}"
                                    BorderBrush="{StaticResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <TextBlock Text="{Binding LinkProcessLogText}"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           LineHeight="18"
                                           Foreground="{StaticResource AppMutedTextBrush}"
                                           TextWrapping="Wrap" />
                            </Border>
                            <Button Content="打开日志目录"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,0"
                                    MinWidth="120"
                                    Command="{Binding OpenLinkLogsCommand}" />
                            <TextBlock Text="自定义节点 / Peer"
                                       Margin="0,16,0,6"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding CustomPeer, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="68"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="4">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,12,0,12"
                                   Foreground="{StaticResource AppAccentBrush}"
                                   TextWrapping="Wrap" />
                        <UniformGrid Columns="3">
                            <Button Content="保存设置"
                                    Margin="0,0,6,0"
                                    Command="{Binding SaveLinkSettingsCommand}" />
                            <Button Content="Terracotta"
                                    Margin="6,0"
                                    Command="{Binding OpenTerracottaCommand}" />
                            <Button Content="EasyTier"
                                    Margin="6,0,0,0"
                                    Command="{Binding OpenEasyTierCommand}" />
                        </UniformGrid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3"
                   Text="联机后端契约、启动计划、端口转发和近期日志已接入；二进制下载、异常恢复与节点配置会继续补齐。"
                   Margin="0,14,0,0"
                   Foreground="{StaticResource AppAccentBrush}" />
    </Grid>
</UserControl>
