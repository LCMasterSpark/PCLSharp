<UserControl x:Class="PCLrmkBYCSharp.Views.Pages.DownloadPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}"
             Foreground="{StaticResource AppTextBrush}">
    <UserControl.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template" Value="{StaticResource DarkButtonTemplate}" />
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource DarkComboBoxStyle}">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource DarkComboBoxItemStyle}">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Padding" Value="8,5" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title}" FontSize="30" FontWeight="SemiBold" />
        <TextBlock Grid.Row="1"
                   Text="{Binding Subtitle}"
                   Margin="0,8,0,22"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   FontSize="14" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Background="{StaticResource AppCardBrush}"
                    BorderBrush="{StaticResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="下载分类"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />
                    <ListBox ItemsSource="{Binding Sections}"
                             SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource AppTextBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,6">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Description}"
                                               Margin="0,4,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource AppMutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Padding="16"
                        Background="{StaticResource AppCardBrush}"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding SectionTitle}" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SectionDescription}"
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource AppMutedTextBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="刷新"
                                MinWidth="78"
                                Command="{Binding RefreshCurrentSectionCommand}" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="0,14,0,0">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsInstallSection}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="16"
                            Background="{StaticResource AppCardBrush}"
                            BorderBrush="{StaticResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Minecraft 根目录" FontSize="15" FontWeight="SemiBold" />
                            <TextBox Grid.Row="1"
                                     Margin="0,10,0,0"
                                     Text="{Binding MinecraftRootPath, UpdateSourceTrigger=PropertyChanged}"
                                     IsReadOnly="True" />
                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding MinecraftRootFolders}"
                                     SelectedItem="{Binding SelectedMinecraftRootFolder, Mode=TwoWay}"
                                     Margin="0,10,0,0"
                                     MaxHeight="92"
                                     Background="Transparent"
                                     BorderBrush="{StaticResource AppBorderBrush}"
                                     Foreground="{StaticResource AppTextBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Path}"
                                                           Margin="0,3,0,0"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{StaticResource AppMutedTextBrush}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding TypeText}"
                                                       Margin="8,0,0,0"
                                                       Foreground="{StaticResource AppAccentBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Grid Grid.Row="3" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Content="添加文件夹"
                                        Command="{Binding BrowseMinecraftRootCommand}" />
                                <Button Grid.Column="2"
                                        Content="重命名"
                                        Command="{Binding RenameMinecraftRootCommand}" />
                                <Button Grid.Column="4"
                                        Content="移除"
                                        Command="{Binding RemoveMinecraftRootCommand}" />
                            </Grid>
                            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="打开文件夹"
                                        MinWidth="98"
                                        Command="{Binding OpenMinecraftRootCommand}" />
                                <Button Content="刷新版本列表"
                                        MinWidth="112"
                                        Margin="10,0,0,0"
                                        Command="{Binding RefreshVersionsCommand}" />
                                <TextBlock Text="{Binding VersionCount, StringFormat=版本数：{0}}"
                                           Margin="14,5,0,0"
                                           Foreground="{StaticResource AppMutedTextBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="150" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding VersionCount, StringFormat=显示 {0} 个可下载版本}"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                    <ComboBox Grid.Column="2"
                                              ItemsSource="{Binding VersionCategoryOptions}"
                                              SelectedItem="{Binding SelectedVersionCategory, Mode=TwoWay}" />
                                </Grid>
                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding VersionCategoryItems}"
                                         SelectedValuePath="Title"
                                         SelectedValue="{Binding SelectedVersionCategory, Mode=TwoWay}"
                                         Margin="0,10,0,0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource BaseListBoxItemStyle}">
                                            <Setter Property="Margin" Value="0,0,8,0" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="CategoryCard"
                                                    MinHeight="62"
                                                    Padding="10,8"
                                                    Background="{StaticResource AppPanelBrush}"
                                                    BorderBrush="{StaticResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="5">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <DockPanel>
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock DockPanel.Dock="Right"
                                                                   Text="{Binding CountText}"
                                                                   Margin="8,0,0,0"
                                                                   Foreground="{StaticResource AppAccentBrush}" />
                                                    </DockPanel>
                                                    <TextBlock Grid.Row="1"
                                                               Text="{Binding Description}"
                                                               Margin="0,5,0,0"
                                                               FontSize="12"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter TargetName="CategoryCard" Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
                                                    <Setter TargetName="CategoryCard" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                            <ListBox ItemsSource="{Binding Versions}"
                                 SelectedItem="{Binding SelectedVersion}"
                                 Background="{StaticResource AppPanelBrush}"
                                 BorderBrush="{StaticResource AppBorderBrush}"
                                 Foreground="{StaticResource AppTextBrush}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,2" MinHeight="42">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Id}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding ReleaseTime, StringFormat=发布时间：{0:yyyy-MM-dd HH:mm}}"
                                                       Margin="0,3,0,0"
                                                       FontSize="12"
                                                       Foreground="{StaticResource AppMutedTextBrush}" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Padding="8,2"
                                                Margin="10,5,0,5"
                                                Background="{StaticResource AppAccentSoftBrush}"
                                                BorderBrush="{StaticResource AppAccentBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <TextBlock Text="{Binding TypeText}" Foreground="{StaticResource AppTextBrush}" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>

                        <Border Grid.Column="2"
                                Padding="16"
                                Background="{StaticResource AppCardBrush}"
                                BorderBrush="{StaticResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="130" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedInstallMode}" FontSize="15" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <ComboBox Grid.Column="2"
                                              ItemsSource="{Binding InstallModeOptions}"
                                              SelectedItem="{Binding SelectedInstallMode, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="3"
                                               Text="{Binding SelectedVersion.Id, TargetNullValue=未选择版本}"
                                               Margin="0,10,0,0"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>

                                <StackPanel Margin="0,16,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsVanillaInstallMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="实例名称" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding InstanceName, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,6,0,0" />
                                    <Button Content="下载原版"
                                            Margin="0,14,0,0"
                                            MinHeight="34"
                                            HorizontalAlignment="Left"
                                            Command="{Binding InstallSelectedVersionCommand}" />
                                </StackPanel>

                                <StackPanel Margin="0,16,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLoaderInstallMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="生成独立加载器实例，并同时补齐原版依赖"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                    <TextBlock Text="加载器" Margin="0,12,0,5" FontWeight="SemiBold" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox ItemsSource="{Binding LoaderInstallOptions}"
                                                  SelectedItem="{Binding SelectedLoaderKind, Mode=TwoWay}" />
                                        <Button Grid.Column="2"
                                                Content="刷新版本"
                                                MinWidth="82"
                                                Command="{Binding RefreshLoaderVersionsCommand}" />
                                    </Grid>
                                    <TextBlock Text="{Binding LoaderVersionCount, StringFormat=可选版本：{0}}"
                                               Margin="0,8,0,0"
                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                    <TextBlock Text="加载器版本" Margin="0,10,0,5" FontWeight="SemiBold" />
                                    <ComboBox ItemsSource="{Binding LoaderVersions}"
                                              SelectedItem="{Binding SelectedLoaderVersion, Mode=TwoWay}"
                                              DisplayMemberPath="DisplayName" />
                                    <TextBlock Text="手动版本" Margin="0,10,0,5" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding LoaderVersion, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding LoaderInstancePreview}"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource AppAccentBrush}" />
                                    <Button Content="下载并安装加载器"
                                            Margin="0,14,0,0"
                                            MinHeight="34"
                                            HorizontalAlignment="Left"
                                            Command="{Binding InstallSelectedLoaderCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Grid.Row="1" Margin="0,14,0,0">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsResourceSection}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="16"
                            Background="{StaticResource AppCardBrush}"
                            BorderBrush="{StaticResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding ResourcePanelTitle}" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ResourcePanelMessage}"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource AppMutedTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Grid Grid.Row="1" Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="0.68*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="0.62*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="0.72*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding ResourceSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="搜索关键词" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding ResourceGameVersion, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Minecraft 版本，例如 1.20.1" />
                                <ComboBox Grid.Column="4"
                                          ItemsSource="{Binding ResourceLoaderOptions}"
                                          SelectedItem="{Binding ResourceLoader}" />
                                <ComboBox Grid.Column="6"
                                          ItemsSource="{Binding ResourceSourceOptions}"
                                          SelectedItem="{Binding SelectedResourceSource}" />
                                <Button Grid.Column="8"
                                        Content="搜索"
                                        MinWidth="82"
                                        Command="{Binding SearchResourcesCommand}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="0.85*" />
                        </Grid.ColumnDefinitions>
                        <ListBox ItemsSource="{Binding ResourceProjects}"
                                 SelectedItem="{Binding SelectedResourceProject, Mode=TwoWay}"
                                 Background="{StaticResource AppPanelBrush}"
                                 BorderBrush="{StaticResource AppBorderBrush}"
                                 Foreground="{StaticResource AppTextBrush}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="6" MinHeight="70">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40"
                                                Height="40"
                                                CornerRadius="4"
                                                Background="{StaticResource AppCardBrush}"
                                                BorderBrush="{StaticResource AppBorderBrush}"
                                                BorderThickness="1"
                                                VerticalAlignment="Top">
                                            <Image Source="{Binding DisplayIcon}"
                                                   Width="32"
                                                   Height="32"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="2">
                                            <DockPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding PlatformName}"
                                                           Foreground="{StaticResource AppMutedTextBrush}" />
                                            </DockPanel>
                                            <TextBlock Text="{Binding Description}"
                                                       Margin="0,6,0,0"
                                                       Foreground="{StaticResource AppMutedTextBrush}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="40" />
                                             <TextBlock Text="{Binding VersionSummary}"
                                                        Margin="0,6,0,0"
                                                        FontSize="12"
                                                        Foreground="{StaticResource AppAccentBrush}" />
                                             <TextBlock Text="{Binding LoaderSummary, StringFormat=启动平台：{0}}"
                                                        Margin="0,4,0,0"
                                                        FontSize="12"
                                                        Foreground="{StaticResource AppMutedTextBrush}" />
                                         </StackPanel>
                                     </Grid>
                                 </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Column="2"
                                Padding="16"
                                Background="{StaticResource AppCardBrush}"
                                BorderBrush="{StaticResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="资源详情" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SelectedResourceDetail}"
                                               Margin="0,10,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                    <TextBlock Text="{Binding SelectedResourceProject.DownloadCount, StringFormat=下载量：{0}}"
                                               Margin="0,14,0,0"
                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                    <TextBlock Text="{Binding SelectedResourceProject.LoaderSummary, StringFormat=加载器：{0}}"
                                               Margin="0,5,0,0"
                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                    <TextBlock Text="{Binding SelectedResourceGameVersionText}"
                                               Margin="0,5,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                    <TextBlock Text="{Binding SelectedResourceLoaderText}"
                                               Margin="0,5,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                    <TextBlock Text="{Binding SelectedResourceProject.Updated, StringFormat=更新：{0:yyyy-MM-dd}}"
                                               Margin="0,5,0,0"
                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                    <Button Content="刷新可下载版本"
                                            Margin="0,16,0,0"
                                            HorizontalAlignment="Left"
                                            Command="{Binding LoadResourceVersionsCommand}" />
                                    <Button Content="打开项目页面"
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Left"
                                            Command="{Binding OpenSelectedResourceProjectCommand}" />
                                    <TextBlock Text="{Binding ResourceVersionCount, StringFormat=可下载版本：{0}}"
                                               Margin="0,12,0,6"
                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                     <ListBox ItemsSource="{Binding ResourceVersions}"
                                              SelectedItem="{Binding SelectedResourceVersion, Mode=TwoWay}"
                                             MinHeight="120"
                                             MaxHeight="220"
                                             Background="{StaticResource AppPanelBrush}"
                                             BorderBrush="{StaticResource AppBorderBrush}"
                                             Foreground="{StaticResource AppTextBrush}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="4">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding VersionNumber}"
                                                               Margin="0,4,0,0"
                                                               Foreground="{StaticResource AppAccentBrush}" />
                                                    <TextBlock Text="{Binding VersionSummary}"
                                                               Margin="0,4,0,0"
                                                               FontSize="12"
                                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                                </StackPanel>
                                            </DataTemplate>
                                         </ListBox.ItemTemplate>
                                     </ListBox>
                                     <TextBlock Text="{Binding SelectedResourceVersionSummary}"
                                                Margin="0,12,0,0"
                                                TextWrapping="Wrap"
                                                Foreground="{StaticResource AppMutedTextBrush}" />
                                     <TextBlock Text="{Binding SelectedResourceDependencyText}"
                                                Margin="0,6,0,0"
                                                TextWrapping="Wrap"
                                                Foreground="{StaticResource AppMutedTextBrush}" />
                                     <TextBlock Text="{Binding SelectedResourceDependencyListText}"
                                                Margin="0,6,0,0"
                                                TextWrapping="Wrap"
                                                Foreground="{StaticResource AppMutedTextBrush}" />
                                     <TextBlock Text="{Binding SelectedResourceFileSummary}"
                                                Margin="0,6,0,0"
                                                TextWrapping="Wrap"
                                                Foreground="{StaticResource AppMutedTextBrush}" />
                                     <TextBlock Text="{Binding ResourceInstallTarget}"
                                                Margin="0,8,0,0"
                                                TextWrapping="Wrap"
                                                Foreground="{StaticResource AppAccentBrush}" />
                                     <Button Content="{Binding ResourceDownloadActionText}"
                                             Margin="0,14,0,0"
                                             HorizontalAlignment="Left"
                                             Command="{Binding DownloadSelectedResourceFileCommand}" />
                                    <Button Content="安装本地整合包"
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Left"
                                            Command="{Binding InstallLocalModpackCommand}" />
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,14,0,0"
                        Padding="22"
                        Background="{StaticResource AppCardBrush}"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsManagerSection}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="下载管理" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding DownloadTaskCount, StringFormat=任务总数：{0}}"
                                       Margin="0,12,0,0"
                                       Foreground="{StaticResource AppMutedTextBrush}" />
                            <TextBlock Text="{Binding RunningTaskCount, StringFormat=运行中：{0}}"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource AppMutedTextBrush}" />
                            <TextBlock Text="{Binding FailedTaskCount, StringFormat=失败：{0}}"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource AppMutedTextBrush}" />
                            <ProgressBar Margin="0,12,0,0"
                                         Height="6"
                                         Minimum="0"
                                         Maximum="1"
                                         Value="{Binding OverallTaskProgressValue, Mode=OneWay}" />
                            <TextBlock Text="{Binding OverallTaskProgressText, StringFormat=总体进度：{0}}"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource AppMutedTextBrush}" />
                            <TextBlock Text="{Binding DownloadTaskOverviewText}"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource AppAccentBrush}" />
                            <TextBlock Text="{Binding DownloadedFileCountText, StringFormat=文件：{0}}"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource AppMutedTextBrush}" />
                            <TextBlock Text="{Binding DownloadedBytesText, StringFormat=已接收：{0}}"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource AppMutedTextBrush}" />
                            <Button Content="刷新任务"
                                    Margin="0,18,0,0"
                                    Command="{Binding RefreshTaskSnapshotsCommand}" />
                            <Button Content="取消全部运行中"
                                    Margin="0,8,0,0"
                                    Command="{Binding CancelAllRunningDownloadTasksCommand}" />
                            <Button Content="清理已结束"
                                    Margin="0,8,0,0"
                                    Command="{Binding ClearFinishedDownloadTasksCommand}" />
                        </StackPanel>
                        <Grid Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="300" />
                            </Grid.ColumnDefinitions>
                            <ListBox ItemsSource="{Binding DownloadTasks}"
                                     SelectedItem="{Binding SelectedDownloadTask, Mode=TwoWay}"
                                     Background="{StaticResource AppPanelBrush}"
                                     BorderBrush="{StaticResource AppBorderBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="6">
                                            <DockPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource AppTextBrush}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding StateText}"
                                                           Foreground="{StaticResource AppMutedTextBrush}" />
                                            </DockPanel>
                                            <ProgressBar Margin="0,8,0,4"
                                                         Height="6"
                                                         Minimum="0"
                                                         Maximum="1"
                                                         Value="{Binding Progress, Mode=OneWay}" />
                                            <TextBlock Text="{Binding Message}"
                                                       Foreground="{StaticResource AppMutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Border Grid.Column="2"
                                    Padding="12"
                                    Background="{StaticResource AppPanelBrush}"
                                    BorderBrush="{StaticResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                                        <TextBlock Text="{Binding SelectedDownloadTaskActionHint}"
                                                   Margin="0,0,0,10"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource AppMutedTextBrush}" />
                                        <Button Content="取消"
                                                Command="{Binding CancelSelectedDownloadTaskCommand}" />
                                        <Button Content="重试"
                                                Margin="0,8,0,0"
                                                Command="{Binding RetrySelectedDownloadTaskCommand}" />
                                        <Button Content="打开位置"
                                                Margin="0,8,0,0"
                                                Command="{Binding OpenSelectedDownloadTaskFolderCommand}" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="任务详情"
                                                   Margin="0,0,0,10"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <DockPanel>
                                            <TextBlock Text="{Binding SelectedDownloadTaskStateText}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource AppAccentBrush}" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding SelectedDownloadTaskProgressText}"
                                                       Foreground="{StaticResource AppMutedTextBrush}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,10,0,0"
                                                   Text="{Binding SelectedDownloadTaskFileText}"
                                                   Foreground="{StaticResource AppMutedTextBrush}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding SelectedDownloadTaskBytesText}"
                                                   Foreground="{StaticResource AppMutedTextBrush}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding SelectedDownloadTaskPathText}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource AppMutedTextBrush}" />
                                        <TextBlock Margin="0,10,0,0"
                                                   Text="{Binding SelectedDownloadTaskMessage}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource AppTextBrush}" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="4"
                    Padding="16"
                    Background="{StaticResource AppCardBrush}"
                    BorderBrush="{StaticResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding DownloadInfoTitle}"
                               FontSize="17"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding DownloadInfoSummary}"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource AppAccentBrush}" />
                    <Border Grid.Row="2"
                            Margin="0,14,0,0"
                            Padding="12"
                            Background="{StaticResource AppPanelBrush}"
                            BorderBrush="{StaticResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TextBlock Text="{Binding DownloadInfoDetails}"
                                       TextWrapping="Wrap"
                                       LineHeight="20"
                                       Foreground="{StaticResource AppMutedTextBrush}" />
                        </ScrollViewer>
                    </Border>
                    <StackPanel Grid.Row="3" Margin="0,14,0,0">
                        <TextBlock Text="{Binding DownloadTaskCount, StringFormat=当前下载任务：{0} 个}"
                                   Foreground="{StaticResource AppMutedTextBrush}" />
                        <TextBlock Text="{Binding RunningTaskCount, StringFormat=运行中：{0} 个}"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource AppMutedTextBrush}" />
                        <Button Content="打开下载管理"
                                Margin="0,12,0,0"
                                Command="{Binding OpenDownloadManagerCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Margin="0,14,0,0"
                   Foreground="{StaticResource AppMutedTextBrush}" />
    </Grid>
</UserControl>
