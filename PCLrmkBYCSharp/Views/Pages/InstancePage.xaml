<UserControl x:Class="PCLrmkBYCSharp.Views.Pages.InstancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}"
             Foreground="{StaticResource AppTextBrush}">
    <UserControl.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template" Value="{StaticResource DarkButtonTemplate}" />
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource DarkComboBoxStyle}">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource DarkComboBoxItemStyle}">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Padding" Value="8,6" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AppHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Padding" Value="12,7" />
        </Style>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="VersionListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AppHoverBrush}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsHeader}" Value="True">
                    <Setter Property="IsHitTestVisible" Value="False" />
                    <Setter Property="Focusable" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="22">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="410" MinWidth="390" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="版本选择" FontSize="25" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Margin="0,7,0,0"
                               Style="{StaticResource MutedTextStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <Grid MinHeight="320">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Minecraft 文件夹" Style="{StaticResource SectionTitleStyle}" />
                    <TextBox Grid.Row="2"
                             Text="{Binding MinecraftRootPath}"
                             IsReadOnly="True" />
                    <ListBox Grid.Row="4"
                             ItemsSource="{Binding MinecraftRootFolders}"
                             SelectedItem="{Binding SelectedMinecraftRootFolder, Mode=TwoWay}"
                             MinHeight="96"
                             Background="Transparent"
                             BorderBrush="{StaticResource AppBorderBrush}"
                             Foreground="{StaticResource AppTextBrush}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4" Height="72">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Image Source="/Resources/Images/Blocks/Grass.png"
                                           Width="28"
                                           Height="28"
                                           VerticalAlignment="Top"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                    <StackPanel Grid.Column="2">
                                        <DockPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding CurrentText}"
                                                       Margin="10,0,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource AppAccentBrush}" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding Path}"
                                                   Margin="0,3,0,0"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource AppMutedTextBrush}" />
                                        <WrapPanel Margin="0,4,0,0">
                                            <TextBlock Text="{Binding TypeText}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource AppMutedTextBrush}" />
                                            <TextBlock Text="{Binding VersionCountText}"
                                                       Margin="10,0,0,0"
                                                       FontSize="11"
                                                       Foreground="{StaticResource AppMutedTextBrush}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Command="{Binding BrowseMinecraftRootCommand}" Content="添加文件夹" />
                        <Button Grid.Column="2" Command="{Binding RenameMinecraftRootCommand}" Content="重命名" />
                        <Button Grid.Column="4" Command="{Binding RemoveMinecraftRootCommand}" Content="移除" />
                    </Grid>
                    <Grid Grid.Row="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Command="{Binding OpenMinecraftRootCommand}" Content="打开文件夹" />
                        <Button Grid.Column="2" Command="{Binding RefreshCommand}" Content="刷新列表" />
                    </Grid>
                    <Grid Grid.Row="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding InstanceCount, StringFormat=版本：{0}}"
                                   Style="{StaticResource MutedTextStyle}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ErrorCount, StringFormat=异常：{0}}"
                                   HorizontalAlignment="Right"
                                   Style="{StaticResource MutedTextStyle}" />
                    </Grid>
                    <Grid Grid.Row="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding HiddenCount, StringFormat=隐藏：{0}}"
                                   MinWidth="72"
                                   Style="{StaticResource MutedTextStyle}" />
                        <CheckBox Grid.Column="1"
                                  Content="显示隐藏版本"
                                  Margin="12,0,0,0"
                                  IsChecked="{Binding ShowHiddenInstances, Mode=TwoWay}"
                                  Foreground="{StaticResource AppTextBrush}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="本地版本"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Margin="6,4,6,12" />
                    <Grid DockPanel.Dock="Top" Margin="4,0,4,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding InstanceSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="搜索版本名称、版本号、加载器、描述或状态" />
                        <ComboBox Grid.Column="2"
                                  Width="130"
                                  ItemsSource="{Binding VersionSortOptions}"
                                  SelectedValue="{Binding VersionSortMode, Mode=TwoWay}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="DisplayName"
                                  ToolTip="版本排序" />
                    </Grid>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding InstanceListSummary}"
                               Margin="6,0,6,10"
                               Style="{StaticResource MutedTextStyle}" />
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource AppPanelBrush}"
                            BorderBrush="{StaticResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="12"
                            Margin="4,0,4,10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasInstanceRows}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding InstanceListEmptyText}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Style="{StaticResource MutedTextStyle}" />
                    </Border>
                    <ListBox ItemsSource="{Binding InstanceRows}"
                             SelectedItem="{Binding SelectedInstanceRow, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource VersionListItemStyle}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource AppTextBrush}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Border Background="{StaticResource AppAccentSoftBrush}"
                                            BorderBrush="{StaticResource AppAccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            Padding="10,6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding GroupTitle}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AppAccentBrush}" />
                                    </Border>

                                    <Border Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="管理此版本"
                                                          Command="{Binding PlacementTarget.Tag.SelectInstanceCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Instance, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="设为启动版本"
                                                          Command="{Binding PlacementTarget.Tag.UseInstanceForLaunchFromListCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Instance, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="打开版本文件夹"
                                                          Command="{Binding PlacementTarget.Tag.OpenInstanceFolderFromListCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Instance, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <Separator />
                                                <MenuItem Header="收藏/取消收藏"
                                                          Command="{Binding PlacementTarget.Tag.ToggleInstanceStarFromListCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Instance, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="隐藏/取消隐藏"
                                                          Command="{Binding PlacementTarget.Tag.ToggleInstanceHiddenFromListCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Instance, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <Separator />
                                                <MenuItem Header="修改版本名"
                                                          Command="{Binding PlacementTarget.Tag.RenameInstanceFromListCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Instance, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="复制版本"
                                                          Command="{Binding PlacementTarget.Tag.CloneInstanceFromListCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Instance, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="删除版本"
                                                          Command="{Binding PlacementTarget.Tag.DeleteInstanceFromListCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Instance, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Border CornerRadius="5"
                                                MinHeight="108"
                                                Padding="12">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
                                                    <Setter Property="BorderThickness" Value="2" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLaunchVersion}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsManagedVersion}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsLaunchAndManagedVersion}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="32" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="32"
                                                        Height="32"
                                                        VerticalAlignment="Top"
                                                        Background="{StaticResource AppSurfaceBrush}"
                                                        BorderBrush="{StaticResource AppBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="5"
                                                        ToolTip="{Binding IconDescription}">
                                                    <Image Source="{Binding IconPath}"
                                                           Width="24"
                                                           Height="24"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                                </Border>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding DisplayVersion}"
                                                               Margin="0,5,0,0"
                                                               FontSize="12"
                                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                                    <TextBlock Text="{Binding DisplayInfo}"
                                                               Margin="0,5,0,0"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                                    <TextBlock Text="{Binding GroupName}"
                                                               Margin="0,5,0,0"
                                                               FontSize="12"
                                                               Foreground="{StaticResource AppAccentBrush}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="3" Margin="10,0,0,0" MinWidth="76">
                                                    <TextBlock Text="{Binding StarText}"
                                                               HorizontalAlignment="Right"
                                                               Foreground="{StaticResource AppAccentBrush}" />
                                                    <TextBlock Text="{Binding HiddenText}"
                                                               Margin="0,5,0,0"
                                                               HorizontalAlignment="Right"
                                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                                    <TextBlock Text="{Binding StateText}"
                                                               Margin="0,5,0,0"
                                                               HorizontalAlignment="Right"
                                                               Foreground="{StaticResource AppAccentBrush}" />
                                                    <TextBlock Text="{Binding RoleText}"
                                                               Margin="0,5,0,0"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Right"
                                                               Foreground="{StaticResource AppAccentBrush}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorderStyle}" Padding="12">
                <ListBox ItemsSource="{Binding InstanceDetailSections}"
                         SelectedValue="{Binding SelectedInstanceDetailSection, Mode=TwoWay}"
                         SelectedValuePath="Value">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold"
                                           FontSize="14" />
                                <TextBlock Text="{Binding Description}"
                                           Margin="0,4,0,0"
                                           FontSize="11"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Grid Grid.Row="2">

                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsInstanceOverviewSectionSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="300" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="360" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="版本管理" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedInstanceDetail}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextStyle}" />
                            <TextBlock Text="{Binding VersionManagementSummary}"
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource AppAccentBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedInstance.CustomInfo}"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource AppAccentBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="版本概览"
                                       Margin="0,18,0,0"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedInstanceOverview}"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Style="{StaticResource MutedTextStyle}" />
                            <TextBlock Text="路径"
                                       Margin="0,18,0,0"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedInstance.VersionPath}"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextStyle}" />
                            <TextBlock Text="版本详情"
                                       Margin="0,18,0,0"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedInstanceTechnicalDetail}"
                                       Margin="0,6,0,0"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Style="{StaticResource MutedTextStyle}" />
                            <TextBlock Text="{Binding SelectedInstance.ErrorMessage}"
                                       Margin="0,12,0,0"
                                       Foreground="{StaticResource AppAccentBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="常用操作"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8" />
                            <UniformGrid Columns="2" Rows="3">
                                <Button Command="{Binding UseSelectedInstanceForLaunchCommand}"
                                        Content="{Binding SelectedLaunchActionText}"
                                        Margin="0,0,8,8" />
                                <Button Command="{Binding RenameSelectedInstanceCommand}"
                                        Content="修改版本名"
                                        Margin="0,0,0,8" />
                                <Button Command="{Binding CloneSelectedInstanceCommand}"
                                        Content="复制版本"
                                        Margin="0,0,8,8" />
                                <Button Command="{Binding ImportInstanceCommand}"
                                        Content="导入已有版本"
                                        Margin="0,0,0,8" />
                                <Button Command="{Binding ExportSelectedInstanceScriptCommand}"
                                        Content="导出启动脚本"
                                        Margin="0,0,8,0" />
                                <Button Command="{Binding RefreshCommand}"
                                        Content="重新扫描" />
                            </UniformGrid>
                            <Border Margin="0,12,0,12"
                                    Height="1"
                                    Background="{StaticResource AppBorderBrush}" />
                            <TextBlock Text="整合包"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8" />
                            <TextBox Text="{Binding ExportPackName, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="整合包名称" />
                            <TextBox Text="{Binding ExportPackVersion, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,8,0,0"
                                     ToolTip="整合包版本号" />
                            <UniformGrid Columns="4" Margin="0,10,0,0">
                                <CheckBox Content="配置"
                                          Margin="0,0,8,6"
                                          IsChecked="{Binding ExportIncludeConfig, Mode=TwoWay}" />
                                <CheckBox Content="Mod"
                                          Margin="0,0,8,6"
                                          IsChecked="{Binding ExportIncludeMods, Mode=TwoWay}" />
                                <CheckBox Content="资源包"
                                          Margin="0,0,8,6"
                                          IsChecked="{Binding ExportIncludeResourcePacks, Mode=TwoWay}" />
                                <CheckBox Content="光影"
                                          Margin="0,0,8,6"
                                          IsChecked="{Binding ExportIncludeShaderPacks, Mode=TwoWay}" />
                                <CheckBox Content="存档"
                                          Margin="0,0,8,0"
                                          IsChecked="{Binding ExportIncludeSaves, Mode=TwoWay}" />
                                <CheckBox Content="截图"
                                          Margin="0,0,8,0"
                                          IsChecked="{Binding ExportIncludeScreenshots, Mode=TwoWay}" />
                                <CheckBox Content="选项"
                                          Margin="0,0,8,0"
                                          IsChecked="{Binding ExportIncludeOptions, Mode=TwoWay}" />
                            </UniformGrid>
                            <UniformGrid Columns="2" Margin="0,10,0,0">
                                <Button Command="{Binding ExportSelectedInstanceModpackCommand}"
                                        Content="导出整合包"
                                        Margin="0,0,8,0" />
                                <Button Command="{Binding CompleteSelectedInstanceFilesCommand}"
                                        Content="补全文件"
                                        ToolTip="校验版本依赖文件是否完整，并下载缺失或校验失败的文件。" />
                            </UniformGrid>
                            <TextBlock Text="{Binding FileCompletionSummary}"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource AppAccentBrush}"
                                       TextWrapping="Wrap" />
                            <ItemsControl ItemsSource="{Binding FileCompletionDetails}"
                                          Margin="0,6,0,0"
                                          MaxHeight="58">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource AppMutedTextBrush}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border Margin="0,12,0,12"
                                    Height="1"
                                    Background="{StaticResource AppBorderBrush}" />
                            <TextBlock Text="文件夹与状态"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8" />
                            <UniformGrid Columns="2" Rows="5">
                                <Button Command="{Binding OpenSelectedInstanceFolderCommand}"
                                        Content="打开文件夹"
                                        Margin="0,0,8,8" />
                                <Button Command="{Binding OpenSelectedSavesFolderCommand}"
                                        Content="存档文件夹"
                                        Margin="0,0,0,8" />
                                <Button Command="{Binding OpenSelectedModsFolderCommand}"
                                        Content="Mod 文件夹"
                                        Margin="0,0,8,8" />
                                <Button Command="{Binding OpenSelectedResourcePacksFolderCommand}"
                                        Content="资源包文件夹"
                                        Margin="0,0,0,8" />
                                <Button Command="{Binding OpenSelectedShaderPacksFolderCommand}"
                                        Content="光影包文件夹"
                                        Margin="0,0,8,8" />
                                <Button Command="{Binding OpenSelectedScreenshotsFolderCommand}"
                                        Content="截图文件夹"
                                        Margin="0,0,0,8" />
                                <Button Command="{Binding ToggleSelectedInstanceStarCommand}"
                                        Content="{Binding SelectedStarActionText}"
                                        Margin="0,0,8,8" />
                                <Button Command="{Binding ToggleSelectedInstanceHiddenCommand}"
                                        Content="{Binding SelectedHiddenActionText}"
                                        Margin="0,0,0,8" />
                                <Button Command="{Binding DeleteSelectedInstanceCommand}"
                                        Content="删除版本"
                                        Margin="0,0,8,0" />
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsInstanceModSectionSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Mod 管理" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding LocalModsDirectory}"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding LocalModCount, StringFormat=显示：{0}}"
                                       Foreground="{StaticResource AppAccentBrush}"
                                       VerticalAlignment="Top" />
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding LocalModFilterOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding LocalModFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Grid.Column="2"
                                     Text="{Binding LocalModSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="搜索 Mod 名称、文件名、版本或描述" />
                            <Button Grid.Column="4"
                                    Command="{Binding RefreshLocalModsCommand}"
                                    Content="刷新 Mod" />
                        </Grid>

                        <ListBox Grid.Row="4"
                                 ItemsSource="{Binding LocalMods}"
                                 SelectedItem="{Binding SelectedLocalMod, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderBrush="{StaticResource AppBorderBrush}"
                                 Foreground="{StaticResource AppTextBrush}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource AppBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            Padding="10"
                                            Margin="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                      Command="{Binding DataContext.ToggleLocalModSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"
                                                      VerticalAlignment="Top"
                                                      Foreground="{StaticResource AppTextBrush}" />
                                            <StackPanel Grid.Column="2">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Subtitle}"
                                                               Margin="8,0,0,0"
                                                               Foreground="{StaticResource AppAccentBrush}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}"
                                                           Margin="0,5,0,0"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource AppMutedTextBrush}" />
                                                <TextBlock Text="{Binding UpdateText}"
                                                           Margin="0,5,0,0"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource AppAccentBrush}" />
                                                <TextBlock Text="{Binding DetailText}"
                                                           Margin="0,5,0,0"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource AppMutedTextBrush}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="3"
                                                        Margin="12,0,0,0"
                                                        MinWidth="72">
                                                <TextBlock Text="{Binding StateText}"
                                                           HorizontalAlignment="Right"
                                                           Foreground="{StaticResource AppAccentBrush}" />
                                                <TextBlock Text="{Binding SizeText}"
                                                           Margin="0,5,0,0"
                                                           HorizontalAlignment="Right"
                                                           Foreground="{StaticResource AppMutedTextBrush}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Command="{Binding ToggleSelectedLocalModEnabledCommand}"
                                    Content="{Binding SelectedLocalModActionText}"
                                    MinWidth="90" />
                            <Button Grid.Column="2"
                                    Command="{Binding DeleteSelectedLocalModCommand}"
                                    Content="删除"
                                    MinWidth="90" />
                            <Button Grid.Column="4"
                                    Command="{Binding OpenSelectedModsFolderCommand}"
                                    Content="打开文件夹"
                                    MinWidth="110" />
                            <StackPanel Grid.Column="6"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding EnabledLocalModCount, StringFormat=启用：{0}}"
                                           Foreground="{StaticResource AppMutedTextBrush}" />
                                <TextBlock Text="{Binding DisabledLocalModCount, StringFormat= / 禁用：{0}}"
                                           Foreground="{StaticResource AppMutedTextBrush}" />
                                <TextBlock Text="{Binding UpdateLocalModCount, StringFormat= / 可更新：{0}}"
                                           Foreground="{StaticResource AppMutedTextBrush}" />
                            </StackPanel>
                            <Grid Grid.Row="2" Grid.ColumnSpan="7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Command="{Binding SelectAllLocalModsCommand}"
                                        Content="全选"
                                        MinWidth="78" />
                                <Button Grid.Column="2"
                                        Command="{Binding ClearSelectedLocalModsCommand}"
                                        Content="取消选择"
                                        MinWidth="92" />
                                <Button Grid.Column="4"
                                        Command="{Binding EnableSelectedLocalModsCommand}"
                                        Content="启用选中"
                                        MinWidth="92" />
                                <Button Grid.Column="6"
                                        Command="{Binding DisableSelectedLocalModsCommand}"
                                        Content="禁用选中"
                                        MinWidth="92" />
                                <Button Grid.Column="8"
                                        Command="{Binding DeleteSelectedLocalModsCommand}"
                                        Content="删除选中"
                                        MinWidth="92" />
                                <TextBlock Grid.Column="10"
                                           Text="{Binding LocalModSelectionSummary}"
                                           Foreground="{StaticResource AppAccentBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <Grid Grid.Row="4" Grid.ColumnSpan="7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Command="{Binding InstallLocalModsCommand}"
                                        Content="安装 Mod"
                                        MinWidth="96" />
                                <Button Grid.Column="2"
                                        Command="{Binding DownloadModsForSelectedInstanceCommand}"
                                        Content="下载 Mod"
                                        MinWidth="96" />
                                <Button Grid.Column="4"
                                        Command="{Binding CheckLocalModUpdatesCommand}"
                                        Content="检查更新"
                                        MinWidth="96" />
                                <Button Grid.Column="6"
                                        Command="{Binding UpdateSelectedLocalModsCommand}"
                                        Content="更新选中"
                                        MinWidth="96" />
                                <Button Grid.Column="8"
                                        Command="{Binding UpdateAllLocalModsCommand}"
                                        Content="更新全部"
                                        MinWidth="96" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsInstanceLaunchSettingsSectionSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="{Binding InstanceLaunchSettingsTitle}" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="这些设置按旧版 Version* / Launch* 语义保存到当前版本，优先覆盖全局启动设置。"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource MutedTextStyle}" />

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="内存分配" FontWeight="SemiBold" />
                                <ComboBox Margin="0,6,0,0"
                                          ItemsSource="{Binding VersionRamTypeOptions}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding VersionRamType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="自定义内存档位" FontWeight="SemiBold" />
                                <DockPanel Margin="0,6,0,0">
                                    <TextBlock DockPanel.Dock="Right"
                                               Width="34"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               TextAlignment="Right"
                                               Text="{Binding VersionRamCustom}" />
                                    <Slider Minimum="0"
                                            Maximum="49"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding VersionRamCustom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DockPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="窗口宽度" FontWeight="SemiBold" />
                                <TextBox Margin="0,6,0,0" Text="{Binding LaunchWindowWidth, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="6">
                                <TextBlock Text="窗口高度" FontWeight="SemiBold" />
                                <TextBox Margin="0,6,0,0" Text="{Binding LaunchWindowHeight, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="游戏窗口标题" FontWeight="SemiBold" />
                                <TextBox Margin="0,6,0,0" Text="{Binding VersionArgumentTitle, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="版本描述" Margin="0,14,0,6" FontWeight="SemiBold" />
                                <TextBox Text="{Binding VersionCustomInfo, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="额外 JVM 参数" Margin="0,14,0,6" FontWeight="SemiBold" />
                                <TextBox Text="{Binding ExtraJvmArgs, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="额外游戏参数" Margin="0,14,0,6" FontWeight="SemiBold" />
                                <TextBox Text="{Binding ExtraGameArgs, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="版本隔离" FontWeight="SemiBold" />
                                <ComboBox Margin="0,6,0,0"
                                          ItemsSource="{Binding VersionIsolationOptions}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding VersionIsolationEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="开启后，存档、Mod 等文件会保存在该版本文件夹；关闭后与全局 .minecraft 共享。" />
                                <TextBlock Text="{Binding GameDirectoryPath}"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource MutedTextStyle}" />
                                <TextBlock Text="启动前命令" Margin="0,14,0,0" FontWeight="SemiBold" />
                                <TextBox Margin="0,6,0,0" Text="{Binding VersionAdvanceRun, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="等待命令结束"
                                          Margin="0,10,0,0"
                                          IsChecked="{Binding VersionAdvanceRunWait, Mode=TwoWay}"
                                          Foreground="{StaticResource AppTextBrush}" />
                                <TextBlock Text="版本 Java" Margin="0,14,0,6" FontWeight="SemiBold" />
                                <DockPanel>
                                    <Button DockPanel.Dock="Right"
                                            Content="选择文件"
                                            Margin="10,0,0,0"
                                            Command="{Binding BrowseJavaCommand}" />
                                    <TextBox Text="{Binding VersionJavaPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                                </DockPanel>
                                <TextBlock Text="自动进入服务器" Margin="0,14,0,6" FontWeight="SemiBold" />
                                <TextBox Text="{Binding ServerIp, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="服务器登录方式" Margin="0,14,0,6" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding VersionServerLoginOptions}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding VersionServerLogin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Margin="0,10,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsVersionNideServerLogin}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="统一通行证服务器 ID" FontWeight="SemiBold" />
                                    <TextBox Margin="0,6,0,0"
                                             Text="{Binding VersionServerNide, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,10,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsVersionAuthServerLogin}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="Authlib 认证服务器" FontWeight="SemiBold" />
                                    <TextBox Margin="0,6,0,0"
                                             Text="{Binding VersionServerAuthServer, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="注册链接" Margin="0,10,0,6" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding VersionServerAuthRegister, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="服务器名称" Margin="0,10,0,6" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding VersionServerAuthName, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{Binding InstanceLaunchOverrideSummary}"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource AppAccentBrush}"
                                   TextWrapping="Wrap" />

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="GC 设置" FontWeight="SemiBold" />
                                <ComboBox Margin="0,6,0,0"
                                          ItemsSource="{Binding VersionGcOptions}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding VersionGc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="版本分类" FontWeight="SemiBold" />
                                <ComboBox Margin="0,6,0,0"
                                          ItemsSource="{Binding VersionDisplayTypeOptions}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding VersionDisplayType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="内存优化" FontWeight="SemiBold" />
                                <ComboBox Margin="0,6,0,0"
                                          ItemsSource="{Binding VersionRamOptimizeOptions}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding VersionRamOptimize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="6" VerticalAlignment="Bottom">
                                <CheckBox Content="禁用 JLW"
                                          IsChecked="{Binding DisableJlw, Mode=TwoWay}"
                                          Foreground="{StaticResource AppTextBrush}" />
                                <CheckBox Content="禁用 LUA"
                                          Margin="0,8,0,0"
                                          IsChecked="{Binding DisableLua, Mode=TwoWay}"
                                          Foreground="{StaticResource AppTextBrush}" />
                                <CheckBox Content="禁止更新 Mod"
                                          Margin="0,8,0,0"
                                          IsChecked="{Binding DisableModUpdate, Mode=TwoWay}"
                                          Foreground="{StaticResource AppTextBrush}" />
                                <CheckBox Content="忽略 Java 兼容性警告"
                                          Margin="0,8,0,0"
                                          IsChecked="{Binding IgnoreJavaCompatibility, Mode=TwoWay}"
                                          Foreground="{StaticResource AppTextBrush}" />
                                <CheckBox Content="关闭文件校验"
                                          Margin="0,8,0,0"
                                          IsChecked="{Binding DisableFileCheck, Mode=TwoWay}"
                                          Foreground="{StaticResource AppTextBrush}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,20,0,0">
                            <Button Command="{Binding SaveInstanceLaunchSettingsCommand}"
                                Content="保存版本设置"
                                MinWidth="140" />
                            <Button Command="{Binding ResetInstanceLaunchSettingsCommand}"
                                    Content="恢复全局设置"
                                    Margin="10,0,0,0"
                                    MinWidth="120" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
