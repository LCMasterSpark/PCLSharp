<UserControl x:Class="PCLrmkBYCSharp.Views.Pages.OtherPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}"
             Foreground="{StaticResource AppTextBrush}">
    <UserControl.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Padding="14,11"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AppHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="SectionPanelStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title}" FontSize="30" FontWeight="SemiBold" />
        <TextBlock Grid.Row="1"
                   Text="{Binding Subtitle}"
                   Margin="0,8,0,22"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   FontSize="14" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="更多选项"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14" />
                    <ListBox ItemsSource="{Binding OtherSections}"
                             SelectedValue="{Binding SelectedOtherSection, Mode=TwoWay}"
                             SelectedValuePath="Value">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold"
                                               FontSize="14" />
                                    <TextBlock Text="{Binding Description}"
                                               Margin="0,4,0,0"
                                               FontSize="12"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid" BasedOn="{StaticResource SectionPanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOverviewSectionSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ItemsControl ItemsSource="{Binding Cards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="300"
                                        MinHeight="108"
                                        Margin="0,0,14,14"
                                        Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Description}"
                                                   Margin="0,10,0,0"
                                                   Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Row="2"
                            Style="{StaticResource CardBorderStyle}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="关于与社区"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12" />
                            <TextBlock DockPanel.Dock="Bottom"
                                       Text="{Binding AboutActionStatusText}"
                                       Margin="0,10,0,0"
                                       Style="{StaticResource MutedTextStyle}" />
                            <ItemsControl ItemsSource="{Binding AboutLinks}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button MinWidth="150"
                                                MinHeight="54"
                                                Margin="0,0,8,8"
                                                Padding="10,8"
                                                Command="{Binding DataContext.OpenAboutLinkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Description}"
                                                           Margin="0,3,0,0"
                                                           FontSize="11"
                                                           Foreground="{StaticResource AppMutedTextBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid" BasedOn="{StaticResource SectionPanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHelpSectionSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Width="86"
                                Height="32"
                                Margin="10,0,0,0"
                                Command="{Binding RefreshHelpCommand}"
                                Content="刷新" />
                        <TextBox Text="{Binding HelpSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 ToolTip="搜索帮助条目" />
                    </DockPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.86*" MinWidth="320" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="1.64*" MinWidth="560" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top"
                                           Text="{Binding HelpStatusText}"
                                           Margin="0,0,0,10"
                                           Style="{StaticResource MutedTextStyle}" />
                                <ListBox ItemsSource="{Binding HelpResults}"
                                         SelectedItem="{Binding SelectedHelpEntry, Mode=TwoWay}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Description}"
                                                           Margin="0,3,0,0"
                                                           FontSize="11"
                                                           MaxHeight="34"
                                                           Style="{StaticResource MutedTextStyle}" />
                                                <TextBlock Text="{Binding TypeText}"
                                                           Margin="0,3,0,0"
                                                           FontSize="11"
                                                           Foreground="{StaticResource AppAccentBrush}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource CardBorderStyle}">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Bottom"
                                            Margin="0,14,0,0">
                                    <Button MinHeight="34"
                                            MinWidth="96"
                                            HorizontalAlignment="Left"
                                            Padding="18,0"
                                            Command="{Binding OpenSelectedHelpCommand}"
                                            Content="打开" />
                                    <TextBlock Text="{Binding HelpActionStatusText}"
                                               Margin="0,8,0,0"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding SelectedHelpDocumentBlocks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10"
                                                        Padding="14"
                                                        Background="{StaticResource AppSurfaceBrush}"
                                                        BorderBrush="{StaticResource AppBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <StackPanel>
                                                        <TextBlock x:Name="KindText"
                                                                   Text="{Binding Kind}"
                                                                   Foreground="{StaticResource AppMutedTextBrush}"
                                                                   FontSize="10"
                                                                   Margin="0,0,0,4" />
                                                        <TextBlock x:Name="TitleText"
                                                                   Text="{Binding Title}"
                                                                   TextWrapping="Wrap"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="15" />
                                                        <TextBlock x:Name="BodyText"
                                                                   Text="{Binding Text}"
                                                                   Margin="0,7,0,0"
                                                                   TextWrapping="Wrap"
                                                                   LineHeight="20"
                                                                   Foreground="{StaticResource AppTextBrush}" />
                                                        <Image x:Name="HelpImage"
                                                               Source="{Binding Text}"
                                                               MaxHeight="260"
                                                               Stretch="Uniform"
                                                               Margin="0,10,0,0"
                                                               Visibility="Collapsed" />
                                                        <Button x:Name="ActionButton"
                                                                Content="执行"
                                                                MinHeight="30"
                                                                MinWidth="92"
                                                                Margin="0,10,0,0"
                                                                HorizontalAlignment="Left"
                                                                Padding="14,0"
                                                                Command="{Binding DataContext.ExecuteHelpDocumentBlockCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Visibility="Collapsed" />
                                                    </StackPanel>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding Kind}" Value="CardTitle">
                                                        <Setter TargetName="KindText" Property="Visibility" Value="Collapsed" />
                                                        <Setter TargetName="TitleText" Property="FontSize" Value="17" />
                                                        <Setter TargetName="BodyText" Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Paragraph">
                                                        <Setter TargetName="KindText" Property="Visibility" Value="Collapsed" />
                                                        <Setter TargetName="TitleText" Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Hint">
                                                        <Setter TargetName="KindText" Property="Text" Value="提示" />
                                                        <Setter TargetName="BodyText" Property="Foreground" Value="{StaticResource AppAccentBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Warning">
                                                        <Setter TargetName="KindText" Property="Text" Value="注意" />
                                                        <Setter TargetName="BodyText" Property="Foreground" Value="#F6C177" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="ListItem">
                                                        <Setter TargetName="KindText" Property="Text" Value="条目" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Action">
                                                        <Setter TargetName="KindText" Property="Text" Value="操作" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Event">
                                                        <Setter TargetName="KindText" Property="Text" Value="事件" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Image">
                                                        <Setter TargetName="KindText" Property="Text" Value="图片" />
                                                        <Setter TargetName="TitleText" Property="Visibility" Value="Collapsed" />
                                                        <Setter TargetName="BodyText" Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
                                                        <Setter TargetName="HelpImage" Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HasAction}" Value="True">
                                                        <Setter TargetName="ActionButton" Property="Visibility" Value="Visible" />
                                                        <Setter TargetName="ActionButton" Property="Content" Value="打开" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
