<UserControl x:Class="PCLrmkBYCSharp.Views.Pages.OtherPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}"
             Foreground="{StaticResource AppTextBrush}">
    <UserControl.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Padding="14,11"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AppHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="SectionPanelStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title}" FontSize="30" FontWeight="SemiBold" />
        <TextBlock Grid.Row="1"
                   Text="{Binding Subtitle}"
                   Margin="0,8,0,22"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   FontSize="14" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="更多选项"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14" />
                    <ListBox ItemsSource="{Binding OtherSections}"
                             SelectedValue="{Binding SelectedOtherSection, Mode=TwoWay}"
                             SelectedValuePath="Value">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold"
                                               FontSize="14" />
                                    <TextBlock Text="{Binding Description}"
                                               Margin="0,4,0,0"
                                               FontSize="12"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid" BasedOn="{StaticResource SectionPanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOverviewSectionSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ItemsControl ItemsSource="{Binding Cards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="300"
                                        MinHeight="108"
                                        Margin="0,0,14,14"
                                        Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Description}"
                                                   Margin="0,10,0,0"
                                                   Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Row="2"
                            Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="当前方向"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12" />
                            <TextBlock Style="{StaticResource MutedTextStyle}"
                                       LineHeight="21"
                                       Text="更多页现在按原版思路拆成独立分页：帮助用于检索内置 Help，百宝箱承载维护工具，反馈用于记录差异与问题，关于与鸣谢单独说明 PCL Sharp 的实验定位和引用关系。" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid" BasedOn="{StaticResource SectionPanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFeatureHubSectionSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="实验与规划"
                                           FontSize="22"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="这里集中放置暂未完整迁移、但已经预留服务契约和 UI 落点的功能。"
                                           Margin="0,7,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                                <TextBlock Text="{Binding FeatureHubStatusText}"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource AppAccentBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Width="108"
                                    MinHeight="34"
                                    VerticalAlignment="Top"
                                    Command="{Binding RefreshFeatureHubCommand}"
                                    Content="刷新状态" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" MinWidth="420" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="1.4*" MinWidth="520" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top"
                                           Text="功能占位清单"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,12" />
                                <ListBox ItemsSource="{Binding FeatureModules}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Status}"
                                                               DockPanel.Dock="Right"
                                                               Foreground="{StaticResource AppAccentBrush}"
                                                               FontSize="12" />
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               FontSize="14"
                                                               TextWrapping="Wrap" />
                                                </DockPanel>
                                                <TextBlock Text="{Binding Description}"
                                                           Margin="0,5,0,0"
                                                           FontSize="12"
                                                           Style="{StaticResource MutedTextStyle}" />
                                                <TextBlock Text="{Binding NextStep}"
                                                           Margin="0,5,0,0"
                                                           FontSize="12"
                                                           Foreground="{StaticResource AppAccentBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="更新系统"
                                                   FontSize="17"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding UpdateStatusText}"
                                                   Margin="0,7,0,0"
                                                   Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Width="110"
                                            MinHeight="34"
                                            VerticalAlignment="Center"
                                            Command="{Binding CheckUpdateCommand}"
                                            Content="检查更新" />
                                </Grid>
                            </Border>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="崩溃分析" FontWeight="SemiBold" FontSize="16" />
                                        <TextBlock Text="{Binding CrashAnalysisText}"
                                                   Margin="0,8,0,0"
                                                   LineHeight="20"
                                                   Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="账号管理中心" FontWeight="SemiBold" FontSize="16" />
                                        <TextBlock Text="{Binding AccountCenterText}"
                                                   Margin="0,8,0,0"
                                                   LineHeight="20"
                                                   Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="皮肤中心" FontWeight="SemiBold" FontSize="16" />
                                        <TextBlock Text="{Binding SkinCenterText}"
                                                   Margin="0,8,0,0"
                                                   LineHeight="20"
                                                   Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="主页公告" FontWeight="SemiBold" FontSize="16" />
                                        <ItemsControl ItemsSource="{Binding HomeFeedItems}" Margin="0,8,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,10">
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Description}"
                                                                   Margin="0,3,0,0"
                                                                   FontSize="12"
                                                                   Style="{StaticResource MutedTextStyle}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="4" Grid.ColumnSpan="3" Style="{StaticResource CardBorderStyle}">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top"
                                                   Text="扩展点"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Margin="0,0,0,8" />
                                        <TextBlock DockPanel.Dock="Bottom"
                                                   Text="{Binding ExtensionPointText}"
                                                   Margin="0,8,0,0"
                                                   Foreground="{StaticResource AppAccentBrush}"
                                                   TextWrapping="Wrap" />
                                        <ItemsControl ItemsSource="{Binding ExtensionPoints}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="3" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,10,10"
                                                            Padding="10"
                                                            Background="{StaticResource AppSurfaceBrush}"
                                                            BorderBrush="{StaticResource AppBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding Status}"
                                                                       Margin="0,3,0,0"
                                                                       Foreground="{StaticResource AppAccentBrush}"
                                                                       FontSize="12" />
                                                            <TextBlock Text="{Binding Description}"
                                                                       Margin="0,5,0,0"
                                                                       FontSize="12"
                                                                       Style="{StaticResource MutedTextStyle}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid" BasedOn="{StaticResource SectionPanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHelpSectionSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Width="86"
                                Height="32"
                                Margin="10,0,0,0"
                                Command="{Binding RefreshHelpCommand}"
                                Content="刷新" />
                        <TextBox Text="{Binding HelpSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 ToolTip="搜索帮助条目" />
                    </DockPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.86*" MinWidth="320" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="1.64*" MinWidth="560" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top"
                                           Text="{Binding HelpStatusText}"
                                           Margin="0,0,0,10"
                                           Style="{StaticResource MutedTextStyle}" />
                                <ListBox ItemsSource="{Binding HelpResults}"
                                         SelectedItem="{Binding SelectedHelpEntry, Mode=TwoWay}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Description}"
                                                           Margin="0,3,0,0"
                                                           FontSize="11"
                                                           MaxHeight="34"
                                                           Style="{StaticResource MutedTextStyle}" />
                                                <TextBlock Text="{Binding TypeText}"
                                                           Margin="0,3,0,0"
                                                           FontSize="11"
                                                           Foreground="{StaticResource AppAccentBrush}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource CardBorderStyle}">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Bottom"
                                            Margin="0,14,0,0">
                                    <Button MinHeight="34"
                                            MinWidth="96"
                                            HorizontalAlignment="Left"
                                            Padding="18,0"
                                            Command="{Binding OpenSelectedHelpCommand}"
                                            Content="打开" />
                                    <TextBlock Text="{Binding HelpActionStatusText}"
                                               Margin="0,8,0,0"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding SelectedHelpDocumentBlocks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10"
                                                        Padding="14"
                                                        Background="{StaticResource AppSurfaceBrush}"
                                                        BorderBrush="{StaticResource AppBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <StackPanel>
                                                        <TextBlock x:Name="KindText"
                                                                   Text="{Binding Kind}"
                                                                   Foreground="{StaticResource AppMutedTextBrush}"
                                                                   FontSize="10"
                                                                   Margin="0,0,0,4" />
                                                        <TextBlock x:Name="TitleText"
                                                                   Text="{Binding Title}"
                                                                   TextWrapping="Wrap"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="15" />
                                                        <TextBlock x:Name="BodyText"
                                                                   Text="{Binding Text}"
                                                                   Margin="0,7,0,0"
                                                                   TextWrapping="Wrap"
                                                                   LineHeight="20"
                                                                   Foreground="{StaticResource AppTextBrush}" />
                                                        <Image x:Name="HelpImage"
                                                               Source="{Binding Text}"
                                                               MaxHeight="260"
                                                               Stretch="Uniform"
                                                               Margin="0,10,0,0"
                                                               Visibility="Collapsed" />
                                                        <Button x:Name="ActionButton"
                                                                Content="执行"
                                                                MinHeight="30"
                                                                MinWidth="92"
                                                                Margin="0,10,0,0"
                                                                HorizontalAlignment="Left"
                                                                Padding="14,0"
                                                                Command="{Binding DataContext.ExecuteHelpDocumentBlockCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Visibility="Collapsed" />
                                                    </StackPanel>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding Kind}" Value="CardTitle">
                                                        <Setter TargetName="KindText" Property="Visibility" Value="Collapsed" />
                                                        <Setter TargetName="TitleText" Property="FontSize" Value="17" />
                                                        <Setter TargetName="BodyText" Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Paragraph">
                                                        <Setter TargetName="KindText" Property="Visibility" Value="Collapsed" />
                                                        <Setter TargetName="TitleText" Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Hint">
                                                        <Setter TargetName="KindText" Property="Text" Value="提示" />
                                                        <Setter TargetName="BodyText" Property="Foreground" Value="{StaticResource AppAccentBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Warning">
                                                        <Setter TargetName="KindText" Property="Text" Value="注意" />
                                                        <Setter TargetName="BodyText" Property="Foreground" Value="#F6C177" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="ListItem">
                                                        <Setter TargetName="KindText" Property="Text" Value="条目" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Action">
                                                        <Setter TargetName="KindText" Property="Text" Value="操作" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Event">
                                                        <Setter TargetName="KindText" Property="Text" Value="事件" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Image">
                                                        <Setter TargetName="KindText" Property="Text" Value="图片" />
                                                        <Setter TargetName="TitleText" Property="Visibility" Value="Collapsed" />
                                                        <Setter TargetName="BodyText" Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
                                                        <Setter TargetName="HelpImage" Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HasAction}" Value="True">
                                                        <Setter TargetName="ActionButton" Property="Visibility" Value="Visible" />
                                                        <Setter TargetName="ActionButton" Property="Content" Value="打开" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid" BasedOn="{StaticResource SectionPanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsToolBoxSectionSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                                <TextBlock Text="百宝箱"
                                           FontSize="22"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="轻量工具、维护入口和自定义下载会集中放在这里。"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                                <TextBlock Text="{Binding ToolboxStatusText}"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource AppAccentBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <Border Padding="14"
                                            Background="{StaticResource AppSurfaceBrush}"
                                            BorderBrush="{StaticResource AppBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock Text="百宝箱"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <UniformGrid Columns="4" Margin="0,12,0,0">
                                                <Button Margin="0,0,10,0"
                                                        MinHeight="34"
                                                        Command="{Binding RollLuckCommand}"
                                                        Content="今日人品" />
                                                <Button Margin="0,0,10,0"
                                                        MinHeight="34"
                                                        Command="{Binding OptimizeMemoryCommand}"
                                                        Content="内存优化" />
                                                <Button Margin="0,0,10,0"
                                                        MinHeight="34"
                                                        Command="{Binding CleanGameTrashCommand}"
                                                        Content="清理游戏垃圾" />
                                                <Button MinHeight="34"
                                                        Command="{Binding DoNotClickCommand}"
                                                        Content="千万别点" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,14,0,0"
                                            Padding="14"
                                            Background="{StaticResource AppSurfaceBrush}"
                                            BorderBrush="{StaticResource AppAccentSoftBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="回声洞"
                                                           Foreground="{StaticResource AppAccentBrush}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding EchoCaveText}"
                                                           Margin="0,8,12,0"
                                                           Style="{StaticResource MutedTextStyle}" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Width="118"
                                                    MinHeight="34"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding OpenEchoCaveCommand}"
                                                    Content="打开" />
                                        </Grid>
                                    </Border>

                                    <Border Margin="0,14,0,0"
                                            Padding="14"
                                            Background="{StaticResource AppSurfaceBrush}"
                                            BorderBrush="{StaticResource AppBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock Text="下载自定义文件"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="使用 PCL Sharp 的下载队列下载直链文件，任务会显示在下载页右侧。"
                                                       Margin="0,7,0,12"
                                                       Style="{StaticResource MutedTextStyle}" />
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="10" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="10" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="12" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="88" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="96" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="下载地址"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold" />
                                                <TextBox Grid.Column="1"
                                                         Grid.ColumnSpan="3"
                                                         Text="{Binding CustomDownloadUrl, UpdateSourceTrigger=PropertyChanged}" />

                                                <TextBlock Grid.Row="2"
                                                           Text="保存到"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold" />
                                                <TextBox Grid.Row="2"
                                                         Grid.Column="1"
                                                         IsReadOnly="True"
                                                         Text="{Binding CustomDownloadFolder}" />
                                                <Button Grid.Row="2"
                                                        Grid.Column="3"
                                                        Command="{Binding BrowseCustomDownloadFolderCommand}"
                                                        Content="选择" />

                                                <TextBlock Grid.Row="4"
                                                           Text="文件名"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold" />
                                                <TextBox Grid.Row="4"
                                                         Grid.Column="1"
                                                         Grid.ColumnSpan="3"
                                                         Text="{Binding CustomDownloadFileName, UpdateSourceTrigger=PropertyChanged}" />

                                                <TextBlock Grid.Row="6"
                                                           Grid.Column="1"
                                                           Text="{Binding CustomDownloadStatusText}"
                                                           Foreground="{StaticResource AppAccentBrush}"
                                                           TextWrapping="Wrap" />
                                                <Button Grid.Row="6"
                                                        Grid.Column="3"
                                                        MinHeight="34"
                                                        Command="{Binding StartCustomDownloadCommand}"
                                                        Content="下载" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid" BasedOn="{StaticResource SectionPanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFeedbackSectionSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="反馈"
                                       FontSize="22"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="现在优先收集会影响可用性的差异：启动失败、下载链路、设置缺失、列表选择、界面显示异常。"
                                       Margin="0,7,0,0"
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                    </Border>
                    <ItemsControl Grid.Row="2" ItemsSource="{Binding FeedbackItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,12"
                                        MinHeight="130"
                                        Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Description}"
                                                   Margin="0,10,0,0"
                                                   Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid" BasedOn="{StaticResource SectionPanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAboutSectionSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                                <TextBlock Text="关于与鸣谢"
                                           FontSize="22"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="PCL Sharp 是实验性重构项目，不是原版 PCL 的正式发布分支。这里列出项目定位、版权说明和参考生态。"
                                           Margin="0,7,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                                <TextBlock Text="{Binding AboutActionStatusText}"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource AppAccentBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding AboutLinks}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Width="260"
                                                    MinHeight="88"
                                                    Margin="0,0,12,12"
                                                    Padding="14,10"
                                                    HorizontalContentAlignment="Stretch"
                                                    Command="{Binding DataContext.OpenAboutLinkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Group}"
                                                               Foreground="{StaticResource AppAccentBrush}"
                                                               FontSize="11" />
                                                    <TextBlock Text="{Binding Title}"
                                                               Margin="0,3,0,0"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Description}"
                                                               Margin="0,5,0,0"
                                                               FontSize="12"
                                                               Foreground="{StaticResource AppMutedTextBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
