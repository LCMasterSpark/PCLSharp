<Window x:Class="PCLrmkBYCSharp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:pages="clr-namespace:PCLrmkBYCSharp.Views.Pages"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:PCLrmkBYCSharp.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        MinHeight="680"
        MinWidth="1160"
        Height="760"
        Width="1280"
        WindowStyle="None"
        ResizeMode="CanResize"
        Icon="/Resources/Images/icon.ico"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource AppTextBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AppHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,2,0,6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Border x:Name="SelectionMark"
                                    Width="3"
                                    HorizontalAlignment="Left"
                                    Margin="0,7"
                                    CornerRadius="2"
                                    Background="Transparent" />
                            <Border x:Name="ItemBorder"
                                    Margin="10,0,8,0"
                                    Padding="14,9"
                                    CornerRadius="5"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AppHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
                                <Setter TargetName="SelectionMark" Property="Background" Value="{StaticResource AppAccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate DataType="{x:Type vm:LaunchPageViewModel}">
            <pages:LaunchPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DownloadPageViewModel}">
            <pages:DownloadPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LinkPageViewModel}">
            <pages:LinkPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:InstancePageViewModel}">
            <pages:InstancePage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SetupPageViewModel}">
            <pages:SetupPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OtherPageViewModel}">
            <pages:OtherPage />
        </DataTemplate>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F11" Command="{Binding ToggleHiddenVersionsCommand}" />
    </Window.InputBindings>

    <Border BorderBrush="{StaticResource AppBorderBrush}"
            BorderThickness="0"
            Background="{StaticResource AppBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="196" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.ColumnSpan="2"
                    Background="{StaticResource AppAccentSoftBrush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="196" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="16,0,0,0">
                        <Image Source="/Resources/Images/Heads/Logo.png"
                               Width="26"
                               Height="26"
                               Margin="0,0,8,0"
                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                        <TextBlock Text="PCL"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AppTextBrush}" />
                        <TextBlock Text=" Sharp"
                                   Margin="4,1,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource AppMutedTextBrush}" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="{Binding CurrentPage.Title}"
                               VerticalAlignment="Center"
                               Margin="14,0"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppTextBrush}" />

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0">
                        <Button Style="{StaticResource TitleButtonStyle}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Content="-" 
                                Click="MinimizeButton_Click" />
                        <Button Style="{StaticResource TitleButtonStyle}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Content="x"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.RowSpan="2"
                    Background="{StaticResource AppSurfaceBrush}"
                    BorderBrush="{StaticResource AppBorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top"
                                Margin="0,14,0,10">
                        <TextBlock Text="功能"
                                   Margin="24,0,0,8"
                                   FontSize="12"
                                   Foreground="{StaticResource AppMutedTextBrush}" />
                        <ListBox ItemsSource="{Binding Pages}"
                                 SelectedValue="{Binding SelectedRoute, Mode=TwoWay}"
                                 SelectedValuePath="Route">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14" />
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Description}"
                                                   Margin="0,2,0,0"
                                                   FontSize="11"
                                                   Foreground="{StaticResource AppMutedTextBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom"
                                Margin="22,0,18,14">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resources/Images/Heads/PCL2.png"
                                   Width="18"
                                   Height="18"
                                   Margin="0,0,7,0"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            <TextBlock Text="Plain Craft Launcher"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{StaticResource AppMutedTextBrush}" />
                        </StackPanel>
                        <TextBlock Text="Sharp 重构进行中"
                                   Margin="25,2,0,0"
                                   FontSize="11"
                                   Foreground="{StaticResource AppAccentBrush}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Background="{StaticResource AppBackgroundBrush}">
                <ContentControl Content="{Binding CurrentPage}" />
            </Border>

            <Border Grid.Column="1"
                    Grid.Row="2"
                    Background="{StaticResource AppStatusBrush}"
                    BorderBrush="{StaticResource AppBorderBrush}"
                    BorderThickness="0,1,0,0">
                <DockPanel Margin="14,0">
                    <TextBlock Text="{Binding LoaderStatusText}"
                               DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource AppMutedTextBrush}" />
                    <TextBlock Text="{Binding StatusText}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource AppMutedTextBrush}" />
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
